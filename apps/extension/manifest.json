{
  "manifest_version": 3,
  "name": "Proctorix Exam Guard",
  "version": "2.0.0",
  "description": "Exam proctoring extension for Proctorix",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "https://yourdomain.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
  {
    "matches": ["http://localhost:*/*", "https://yourdomain.com/*"],
    "js": ["content.js"],
    "run_at": "document_start"
  }
],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Proctorix Proctor"
  }
}