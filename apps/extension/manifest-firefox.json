{
  "manifest_version": 2,
  "name": "Proctorix Exam Guard",
  "version": "2.0.0",
  "description": "Exam proctoring extension for Proctorix",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "http://localhost:*/*",
    "https://yourdomain.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "https://yourdomain.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Proctorix Proctor"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "proctorix@exam-guard",
      "strict_min_version": "109.0"
    }
  }
}